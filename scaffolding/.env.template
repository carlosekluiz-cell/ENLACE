# ENLACE Platform — Environment Configuration Template
# Copy to .env and fill in all REQUIRED values before running.
# Do NOT commit the .env file to version control.

# ═══ Dev Mode ═══
# Set to 0 in production to enforce secret validation
DEV_MODE=1

# ═══ Database (REQUIRED) ═══
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=enlace
POSTGRES_USER=enlace
POSTGRES_PASSWORD=<your-secure-password-here>

# ═══ Redis ═══
REDIS_URL=redis://localhost:6379/0

# ═══ MinIO (S3-compatible object storage) (REQUIRED) ═══
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=enlace_minio
MINIO_ROOT_PASSWORD=<your-secure-minio-password-here>
MINIO_BUCKET_TERRAIN=terrain
MINIO_BUCKET_LANDCOVER=landcover
MINIO_BUCKET_COVERAGE=coverage-maps
MINIO_BUCKET_REPORTS=reports
MINIO_BUCKET_RAW=raw-downloads

# ═══ Data Sources ═══
# NASA Earthdata credentials (free registration at urs.earthdata.nasa.gov)
EARTHDATA_USERNAME=
EARTHDATA_PASSWORD=

# ═══ RF Engine (Rust gRPC service) ═══
RF_ENGINE_HOST=localhost
RF_ENGINE_PORT=50051
SRTM_TILE_DIR=/data/terrain/srtm

# ═══ API (REQUIRED) ═══
API_HOST=0.0.0.0
API_PORT=8000
JWT_SECRET_KEY=<your-secure-jwt-secret-here>
API_CORS_ORIGINS=http://localhost:3000

# ═══ Frontend ═══
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MAPBOX_TOKEN=  # Get from mapbox.com (free tier available)

# ═══ Pipeline Scheduling ═══
PIPELINE_ANATEL_CRON=0 6 15 * *     # 15th of each month at 6am
PIPELINE_INMET_CRON=0 */6 * * *     # Every 6 hours
PIPELINE_OSM_CRON=0 3 1 * *         # 1st of each month at 3am

# ═══ Country Configuration ═══
DEFAULT_COUNTRY=BR
SUPPORTED_COUNTRIES=BR

# ═══ Logging ═══
LOG_LEVEL=info
RUST_LOG=enlace=debug,info
