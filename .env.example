# ============================================================================
# ENLACE Platform — Environment Variables Template
#
# Copy this file to .env and fill in all required values:
#   cp .env.example .env
#
# REQUIRED fields are marked with (REQUIRED). The platform will refuse to
# start in production (DEV_MODE=0) if any required secret is missing.
# ============================================================================

# Dev mode flag — set to 0 in production to enforce secret validation
DEV_MODE=1

# PostgreSQL (REQUIRED)
POSTGRES_PASSWORD=<your-secure-password-here>
POSTGRES_DB=enlace
POSTGRES_USER=enlace
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379

# MinIO (REQUIRED)
MINIO_ROOT_USER=enlace_minio
MINIO_ROOT_PASSWORD=<your-secure-minio-password-here>
MINIO_ENDPOINT=localhost:9000

# JWT Authentication (REQUIRED)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=<your-secure-jwt-secret-here>

# DB connection aliases used by validation scripts and ML modules
DB_HOST=localhost
DB_PORT=5432
DB_NAME=enlace
DB_USER=enlace
DB_PASSWORD=<your-secure-password-here>
